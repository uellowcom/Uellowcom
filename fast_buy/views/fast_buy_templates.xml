<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="product_fast_buy_button" inherit_id="website_sale.product"
              active="True" customize_show="True" name="Fast Order Button">
        <xpath expr="//div[@id='add_to_cart_wrap']" position="inside">
            <div class="qc-btn-wrap"
                 style="display:inline-block;margin-top:8px;position:relative;vertical-align:middle;"
                 t-att-data-template-id="product.id"
                 t-att-data-product-tmpl-id="product.id"
                 t-att-data-default-product-id="product.product_variant_ids[:1].id or product.product_variant_id.id">
                <span style="position:absolute;top:-9px;left:50%;transform:translateX(-50%);
                    background:#e53935;color:#fff;font-size:9px;font-weight:800;
                    padding:2px 8px;border-radius:20px;white-space:nowrap;z-index:1;">
                    <t t-if="request.lang.code.startswith('ar')">في 5 ثوانٍ</t>
                    <t t-else="">in 5 Sec</t>
                </span>
                <button type="button" class="btn btn-primary qc-open-btn" 
                   style="font-weight:800;font-size:15px;white-space:nowrap;
                          border:none;cursor:pointer;border-radius:8px;color:#3e2000;
                          background:linear-gradient(135deg,#fdd835 0%,#ffb300 100%);
                          box-shadow:0 4px 14px rgba(253,216,53,.45);">
                    <i class="fa fa-bolt me-1"/>
                    <t t-if="request.lang.code.startswith('ar')">طلب سريع</t>
                    <t t-else="">Fast Order</t>
                </button>
            </div>
        </xpath>
    </template>

    <!-- Fast Buy trigger - tiny inline script to activate bundle -->
    <template id="fb_trigger" inherit_id="website.layout" active="True" name="Fast Buy Trigger">
        <xpath expr="//body" position="inside">
            <script type="text/javascript"><![CDATA[
(function poll(){
    if(typeof window!=='undefined'&&document.readyState!=='loading'){
        // Force-execute our module if bundle loaded it
        var s=document.createElement('script');
        s.src='/fast_buy/static/src/js/fast_buy_main.js?t='+Date.now();
        document.head.appendChild(s);
    }else{
        setTimeout(poll,50);
    }
})();
            ]]></script>
        </xpath>
    </template>

</odoo>
