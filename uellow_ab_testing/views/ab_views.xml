<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_ab_list" model="ir.ui.view">
    <field name="name">uellow.ab.test.list</field>
    <field name="model">uellow.ab.test</field>
    <field name="arch" type="xml">
      <list string="A/B Tests" decoration-success="winner=='b'" decoration-info="state=='running'">
        <field name="name"/><field name="product_id"/><field name="test_type"/>
        <field name="a_views"/><field name="a_conv_rate" string="A%"/>
        <field name="b_views"/><field name="b_conv_rate" string="B%"/>
        <field name="winner" widget="badge" decoration-success="winner=='b'" decoration-info="winner=='a'"/>
        <field name="state" widget="badge"/>
        <button name="action_start" string="Start" type="object" icon="fa-play" invisible="state!='draft'"/>
        <button name="action_apply_winner" string="Apply Winner" type="object" icon="fa-check" invisible="state!='running' or not winner or winner=='tie'"/>
      </list>
    </field>
  </record>
  <record id="view_ab_form" model="ir.ui.view">
    <field name="name">uellow.ab.test.form</field>
    <field name="model">uellow.ab.test</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_start" string="Start Test" type="object" class="oe_highlight" invisible="state!='draft'"/>
          <button name="action_apply_winner" string="Apply Winner" type="object" class="oe_highlight" invisible="state!='running' or not winner or winner=='tie'"/>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <group>
            <group><field name="name"/><field name="product_id"/><field name="test_type"/><field name="traffic_split"/><field name="min_sample_size"/></group>
            <group string="Results">
              <field name="a_views" readonly="1"/><field name="a_conv_rate" readonly="1"/>
              <field name="b_views" readonly="1"/><field name="b_conv_rate" readonly="1"/>
              <field name="winner" readonly="1" widget="badge"/>
            </group>
          </group>
          <group>
            <group string="Variant A (Control)"><field name="variant_a_label"/><field name="variant_a_value"/></group>
            <group string="Variant B (Challenger)"><field name="variant_b_label"/><field name="variant_b_value"/></group>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>
  <record id="action_ab_tests" model="ir.actions.act_window">
    <field name="name">A/B Tests</field><field name="res_model">uellow.ab.test</field><field name="view_mode">list,form</field>
  </record>
</odoo>
