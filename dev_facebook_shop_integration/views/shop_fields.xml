<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shop_fields_list" model="ir.ui.view">
        <field name="name">shop.fields.list</field>
        <field name="model">shop.fields</field>
        <field name="arch" type="xml">
            <list string="Shop Fields">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_shop_fields_form" model="ir.ui.view">
        <field name="name">shop.fields.form</field>
        <field name="model">shop.fields</field>
        <field name="arch" type="xml">
            <form string="Shop Fields">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="field_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_view_shop_fields" model="ir.actions.act_window">
        <field name="name">Shop Fields</field>
        <field name="res_model">shop.fields</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Click to create add new page.
            </p>
        </field>
    </record>

    <menuitem action="action_view_shop_fields"
              id="shop_fields_menu"
              name="Facebook Shop Fields"
              parent="dev_facebook_shop_integration.facebook_configuration" sequence="1"/>
</odoo>
