<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="inherit_product_temp_form_view" model="ir.ui.view">
        <field name="name">inherit.product.template.view.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="condition"/>
                <field name="brand_id"/>
                <field name="facebook_category_id"/>
                <field name="google_category_id"/>
                <field name="gtin" placeholder="For example: 4011200296908 13-digit number"/>
                <field name="mpn"/>
            </xpath>
        </field>
    </record>
    <record id="inherit_product_form_view" model="ir.ui.view">
        <field name="name">inherit.product.template.view.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="condition"/>
                <field name="brand_id"/>
                <field name="facebook_category_id"/>
                <field name="google_category_id"/>
                <field name="gtin" placeholder="For example: 4011200296908 13-digit number"/>
                <field name="mpn"/>
            </xpath>
        </field>
    </record>
</odoo>
