<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_facebook_google_category_list" model="ir.ui.view">
        <field name="name">facebook.google.category.list</field>
        <field name="model">facebook.google.category</field>
        <field name="arch" type="xml">
            <list string="Facebook Google Category">
                <field name="url"/>
                <field name="platform"/>
            </list>
        </field>
    </record>

    <record id="view_facebook_google_category_form" model="ir.ui.view">
        <field name="name">facebook.google.category.form</field>
        <field name="model">facebook.google.category</field>
        <field name="arch" type="xml">
            <form string="Facebook Google Category">
                <sheet>
                    <group>
                        <field name="url" readonly="1"/>
                        <field name="platform" required="1" readonly="1"/>
                    </group>
                </sheet>
                 <footer>
                    <button string="Update" type="object" name="action_update" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_view_facebook_google_category" model="ir.actions.act_window">
        <field name="name">Facebook Google Category</field>
        <field name="res_model">facebook.google.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Click to create add new page.
            </p>
        </field>
    </record>
