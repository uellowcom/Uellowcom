<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mobile_notification_view_list" model="ir.ui.view">
        <field name="name">mobile.notification.list</field>
        <field name="model">mobile.notification</field>
        <field name="arch" type="xml">
            <list string="Push Notifications" default_order="create_date desc">
                <field name="name"/>
                <field name="target_audience"/>
                <field name="send_type"/>
                <field name="scheduled_date" optional="show"/>
                <field name="sent_count"/>
                <field name="sent_date" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'sent'"
                       decoration-warning="state == 'scheduled'"
                       decoration-danger="state == 'failed'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="mobile_notification_view_form" model="ir.ui.view">
        <field name="name">mobile.notification.form</field>
        <field name="model">mobile.notification</field>
        <field name="arch" type="xml">
            <form string="Push Notification">
                <header>
                    <button name="action_send_now" string="Send Now" type="object"
                            class="btn-primary"
                            invisible="state in ['sent', 'failed']"/>
                    <button name="action_schedule" string="Schedule" type="object"
                            invisible="send_type != 'scheduled' or state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,scheduled,sent"/>
                </header>
                <sheet>
                    <group>
                        <group string="Message">
                            <field name="name" placeholder="Notification Title"/>
                            <field name="body" placeholder="Message body..."/>
                            <field name="image" widget="image" options="{'size': [200, 100]}"/>
                        </group>
                        <group string="Targeting">
                            <field name="target_audience"/>
                            <field name="user_ids" widget="many2many_tags"
                                   invisible="target_audience != 'specific'"/>
                            <field name="segment"
                                   invisible="target_audience != 'segment'"/>
                        </group>
                    </group>
                    <group string="Action on Tap">
                        <field name="action_type" widget="radio"/>
                        <field name="product_id" invisible="action_type != 'product'"/>
                        <field name="category_id" invisible="action_type != 'category'"/>
                        <field name="action_url" invisible="action_type != 'url'"/>
                    </group>
                    <group string="Delivery">
                        <field name="send_type" widget="radio"/>
                        <field name="scheduled_date" invisible="send_type != 'scheduled'"
                               required="send_type == 'scheduled'"/>
                        <field name="website_id"/>
                    </group>
                    <group string="Results" invisible="state != 'sent'">
                        <field name="sent_count" readonly="1"/>
                        <field name="sent_date" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mobile_notification" model="ir.actions.act_window">
        <field name="name">Push Notifications</field>
        <field name="res_model">mobile.notification</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_state': 'draft'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Send your first push notification!</p>
        </field>
    </record>

</odoo>
