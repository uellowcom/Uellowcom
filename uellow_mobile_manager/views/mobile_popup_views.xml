<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mobile_popup_view_list" model="ir.ui.view">
        <field name="name">mobile.popup.list</field>
        <field name="model">mobile.popup</field>
        <field name="arch" type="xml">
            <list string="App Popups" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="image" widget="image" options="{'size': [60, 40]}"/>
                <field name="name"/>
                <field name="trigger"/>
                <field name="frequency"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active" widget="toggle_button"/>
            </list>
        </field>
    </record>

    <record id="mobile_popup_view_form" model="ir.ui.view">
        <field name="name">mobile.popup.form</field>
        <field name="model">mobile.popup</field>
        <field name="arch" type="xml">
            <form string="App Popup">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Popup Name..."/></h1>
                    </div>
                    <group>
                        <group string="Image">
                            <field name="image" widget="image"
                                   options="{'size': [300, 400]}" nolabel="1"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                        <group string="Display Settings">
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="trigger"/>
                            <field name="frequency"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="website_id"/>
                        </group>
                    </group>
                    <group string="On Tap Action">
                        <field name="action_type" widget="radio"/>
                        <field name="product_id" invisible="action_type != 'product'"/>
                        <field name="category_id" invisible="action_type != 'category'"/>
                        <field name="action_url" invisible="action_type != 'url'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mobile_popup" model="ir.actions.act_window">
        <field name="name">App Popups</field>
        <field name="res_model">mobile.popup</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a promotional popup!</p>
            <p>Popups appear as interstitial banners when users open the app or visit the home page.</p>
        </field>
    </record>

</odoo>
