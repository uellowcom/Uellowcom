<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- KANBAN VIEW - Visual Slider Management -->
    <record id="mobile_slider_view_kanban" model="ir.ui.view">
        <field name="name">mobile.slider.kanban</field>
        <field name="model">mobile.slider</field>
        <field name="arch" type="xml">
            <kanban default_group_by="active" class="o_kanban_mobile_slider">
                <field name="name"/>
                <field name="image"/>
                <field name="sequence"/>
                <field name="active"/>
                <field name="action_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click" style="min-width: 240px;">
                            <div class="o_kanban_image_wrapper" style="height: 120px; overflow: hidden; border-radius: 8px 8px 0 0; background: #f0f0f0;">
                                <img t-att-src="kanban_image('mobile.slider', 'image', record.id.raw_value)"
                                     style="width: 100%; height: 100%; object-fit: cover;"
                                     alt="Slider Image"/>
                            </div>
                            <div class="oe_kanban_details p-2">
                                <strong><field name="name"/></strong>
                                <div class="mt-1">
                                    <span class="badge rounded-pill bg-info text-white me-1">
                                        #<field name="sequence"/>
                                    </span>
                                    <span t-if="record.action_type.raw_value != 'none'"
                                          class="badge rounded-pill bg-warning text-dark">
                                        <field name="action_type"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="mobile_slider_view_list" model="ir.ui.view">
        <field name="name">mobile.slider.list</field>
        <field name="model">mobile.slider</field>
        <field name="arch" type="xml">
            <list string="Hero Sliders" editable="top" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="image" widget="image" options="{'size': [60, 40]}"/>
                <field name="name"/>
                <field name="action_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active" widget="toggle_button"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="mobile_slider_view_form" model="ir.ui.view">
        <field name="name">mobile.slider.form</field>
        <field name="model">mobile.slider</field>
        <field name="arch" type="xml">
            <form string="Hero Slider">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Slide Title..."/></h1>
                    </div>
                    <group>
                        <group string="Image">
                            <field name="image" widget="image"
                                   options="{'size': [400, 200]}"
                                   style="max-width: 400px;"
                                   nolabel="1"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                        <group string="Settings">
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="website_id"/>
                        </group>
                    </group>
                    <group string="On Tap Action">
                        <field name="action_type" widget="radio"/>
                        <field name="product_id"
                               invisible="action_type != 'product'"
                               required="action_type == 'product'"/>
                        <field name="category_id"
                               invisible="action_type != 'category'"
                               required="action_type == 'category'"/>
                        <field name="url"
                               invisible="action_type != 'url'"
                               required="action_type == 'url'"/>
                        <field name="search_keyword"
                               invisible="action_type != 'search'"
                               required="action_type == 'search'"/>
                    </group>
                    <group string="Schedule (Optional)">
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_mobile_slider" model="ir.actions.act_window">
        <field name="name">Hero Sliders</field>
        <field name="res_model">mobile.slider</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_active': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first hero slider!
            </p>
            <p>Hero sliders appear at the top of the app home page. Drag to reorder.</p>
        </field>
    </record>

</odoo>
