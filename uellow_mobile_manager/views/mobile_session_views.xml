<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mobile_session_view_list" model="ir.ui.view">
        <field name="name">mobile.session.list</field>
        <field name="model">mobile.session</field>
        <field name="arch" type="xml">
            <list string="App Sessions" create="false" edit="false" default_order="last_activity desc">
                <field name="platform" widget="badge"
                       decoration-success="platform == 'android'"
                       decoration-info="platform == 'ios'"/>
                <field name="device_name"/>
                <field name="customer_name"/>
                <field name="customer_email" optional="show"/>
                <field name="is_guest" widget="boolean_toggle"/>
                <field name="app_version"/>
                <field name="country_code" optional="show"/>
                <field name="ip_address" optional="hide"/>
                <field name="first_seen"/>
                <field name="last_activity"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="mobile_session_view_form" model="ir.ui.view">
        <field name="name">mobile.session.form</field>
        <field name="model">mobile.session</field>
        <field name="arch" type="xml">
            <form string="Session Details" create="false">
                <sheet>
                    <group>
                        <group string="Device">
                            <field name="device_id"/>
                            <field name="device_name"/>
                            <field name="platform"/>
                            <field name="app_version"/>
                            <field name="os_version"/>
                        </group>
                        <group string="User">
                            <field name="is_guest"/>
                            <field name="customer_name"/>
                            <field name="customer_email"/>
                            <field name="odoo_user_id"/>
                            <field name="country_code"/>
                            <field name="ip_address"/>
                        </group>
                    </group>
                    <group string="Activity">
                        <field name="first_seen"/>
                        <field name="last_activity"/>
                        <field name="is_active"/>
                    </group>
                    <group string="Push Token" groups="base.group_system">
                        <field name="fcm_token"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="mobile_session_view_search" model="ir.ui.view">
        <field name="name">mobile.session.search</field>
        <field name="model">mobile.session</field>
        <field name="arch" type="xml">
            <search string="Sessions">
                <field name="device_name"/>
                <field name="customer_name"/>
                <field name="customer_email"/>
                <field name="app_version"/>
                <filter string="Active Now" name="active_now" domain="[('is_active', '=', True)]"/>
                <filter string="Android" name="android" domain="[('platform', '=', 'android')]"/>
                <filter string="iOS" name="ios" domain="[('platform', '=', 'ios')]"/>
                <filter string="Logged In" name="logged_in" domain="[('is_guest', '=', False)]"/>
                <filter string="Guest" name="guest" domain="[('is_guest', '=', True)]"/>
                <group expand="1" string="Group By">
                    <filter string="Platform" name="group_platform" context="{'group_by': 'platform'}"/>
                    <filter string="App Version" name="group_version" context="{'group_by': 'app_version'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mobile_session" model="ir.actions.act_window">
        <field name="name">Active Sessions</field>
        <field name="res_model">mobile.session</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active_now': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No active sessions yet.</p>
            <p>Sessions are registered automatically when users open the app.</p>
        </field>
    </record>

</odoo>
