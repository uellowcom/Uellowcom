<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- KANBAN VIEW -->
    <record id="mobile_category_icon_view_kanban" model="ir.ui.view">
        <field name="name">mobile.category.icon.kanban</field>
        <field name="model">mobile.category.icon</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="icon_image"/>
                <field name="sequence"/>
                <field name="active"/>
                <field name="action_type"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click text-center p-3" style="min-width: 120px; max-width: 140px;">
                            <div style="width: 64px; height: 64px; margin: 0 auto; border-radius: 12px; overflow: hidden; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                                <img t-att-src="kanban_image('mobile.category.icon', 'icon_image', record.id.raw_value)"
                                     style="width: 100%; height: 100%; object-fit: contain;" alt="Icon"/>
                            </div>
                            <div class="mt-2">
                                <strong style="font-size: 12px;"><field name="name"/></strong>
                            </div>
                            <div>
                                <span class="badge rounded-pill bg-secondary" style="font-size: 10px;">#<field name="sequence"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="mobile_category_icon_view_list" model="ir.ui.view">
        <field name="name">mobile.category.icon.list</field>
        <field name="model">mobile.category.icon</field>
        <field name="arch" type="xml">
            <list string="Category Icons" editable="top" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="icon_image" widget="image" options="{'size': [48, 48]}"/>
                <field name="name"/>
                <field name="name_ar"/>
                <field name="action_type"/>
                <field name="category_id" optional="show"/>
                <field name="active" widget="toggle_button"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="mobile_category_icon_view_form" model="ir.ui.view">
        <field name="name">mobile.category.icon.form</field>
        <field name="model">mobile.category.icon</field>
        <field name="arch" type="xml">
            <form string="Category Icon">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Icon Label (English)..."/></h1>
                    </div>
                    <group>
                        <group string="Icon">
                            <field name="icon_image" widget="image"
                                   options="{'size': [120, 120]}"
                                   nolabel="1"/>
                            <field name="icon_filename" invisible="1"/>
                        </group>
                        <group string="Settings">
                            <field name="name"/>
                            <field name="name_ar"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="website_id"/>
                        </group>
                    </group>
                    <group string="On Tap Action">
                        <field name="action_type" widget="radio"/>
                        <field name="category_id"
                               invisible="action_type != 'category'"
                               required="action_type == 'category'"/>
                        <field name="url"
                               invisible="action_type != 'url'"
                               required="action_type == 'url'"/>
                        <field name="search_keyword"
                               invisible="action_type != 'search'"
                               required="action_type == 'search'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_mobile_category_icon" model="ir.actions.act_window">
        <field name="name">Category Icons</field>
        <field name="res_model">mobile.category.icon</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first category icon!</p>
            <p>These icons appear in a horizontal scroll row below the hero slider on the home page.</p>
        </field>
    </record>

</odoo>
