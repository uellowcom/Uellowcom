<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mobile_feature_banner_view_list" model="ir.ui.view">
        <field name="name">mobile.feature.banner.list</field>
        <field name="model">mobile.feature.banner</field>
        <field name="arch" type="xml">
            <list string="Feature Banners" editable="top" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="icon_emoji" optional="show"/>
                <field name="name"/>
                <field name="name_ar"/>
                <field name="description"/>
                <field name="active" widget="toggle_button"/>
            </list>
        </field>
    </record>

    <record id="mobile_feature_banner_view_form" model="ir.ui.view">
        <field name="name">mobile.feature.banner.form</field>
        <field name="model">mobile.feature.banner</field>
        <field name="arch" type="xml">
            <form string="Feature Banner">
                <sheet>
                    <group>
                        <group string="Content">
                            <field name="name" placeholder="e.g. Buyer Protection"/>
                            <field name="name_ar" placeholder="حماية المشتري"/>
                            <field name="description" placeholder="e.g. 100% Safe"/>
                            <field name="description_ar"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Icon">
                            <field name="icon_type" widget="radio"/>
                            <field name="icon_emoji" invisible="icon_type != 'emoji'"/>
                            <field name="icon_image" widget="image"
                                   invisible="icon_type != 'image'"
                                   options="{'size': [80, 80]}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mobile_feature_banner" model="ir.actions.act_window">
        <field name="name">Feature Banners</field>
        <field name="res_model">mobile.feature.banner</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add trust badges!</p>
            <p>These appear as a horizontal strip: "Buyer Protection · Worldwide Delivery · Secure Payment"</p>
        </field>
    </record>

</odoo>
