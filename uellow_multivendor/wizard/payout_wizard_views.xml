<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_payout_wizard" model="ir.ui.view">
    <field name="name">uellow.payout.wizard.form</field>
    <field name="model">uellow.payout.wizard</field>
    <field name="arch" type="xml">
      <form string="Create Payout">
        <sheet>
          <group>
            <field name="vendor_id"/>
            <field name="available_balance" readonly="1"/>
            <field name="currency_id" readonly="1"/>
            <field name="amount"/>
            <field name="payout_date"/>
            <field name="note"/>
          </group>
        </sheet>
        <footer>
          <button name="action_create_payout" string="Create Payout"
                  type="object" class="oe_highlight"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_payout_wizard" model="ir.actions.act_window">
    <field name="name">Create Payout</field>
    <field name="res_model">uellow.payout.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
