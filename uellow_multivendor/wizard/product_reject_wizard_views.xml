<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_product_reject_wizard" model="ir.ui.view">
    <field name="name">uellow.product.reject.wizard.form</field>
    <field name="model">uellow.product.reject.wizard</field>
    <field name="arch" type="xml">
      <form string="Reject Product">
        <sheet>
          <group>
            <field name="product_ids" widget="many2many_tags" readonly="1"/>
            <field name="rejection_reason" placeholder="Enter rejection reason..."/>
          </group>
        </sheet>
        <footer>
          <button name="action_reject" string="Reject Product"
                  type="object" class="oe_highlight btn-danger"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
