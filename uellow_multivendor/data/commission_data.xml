<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Flash sale cron -->
    <record id="cron_flash_sale" model="ir.cron">
        <field name="name">Uellow: Update Flash Sales</field>
        <field name="model_id" ref="model_uellow_flash_sale"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_flash_sales()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
</odoo>
