<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Pending Products List for Admin -->
  <record id="view_vendor_product_approval_list" model="ir.ui.view">
    <field name="name">product.template.vendor.approval.list</field>
    <field name="model">product.template</field>
    <field name="arch" type="xml">
      <list string="Vendor Product Approvals"
            decoration-warning="vendor_approval_state=='pending'"
            decoration-success="vendor_approval_state=='approved'"
            decoration-danger="vendor_approval_state=='rejected'">
        <field name="name" string="Product"/>
        <field name="vendor_id" string="Vendor"/>
        <field name="list_price" string="Price (KD)"/>
        <field name="vendor_submitted_date" string="Submitted"/>
        <field name="vendor_approval_state" widget="badge"
               decoration-warning="vendor_approval_state=='pending'"
               decoration-success="vendor_approval_state=='approved'"
               decoration-danger="vendor_approval_state=='rejected'"
               string="Status"/>
        <button name="action_vendor_approve" string="Approve"
                type="object" icon="fa-check" class="text-success"
                invisible="vendor_approval_state != 'pending'"/>
        <button name="action_vendor_reject" string="Reject"
                type="object" icon="fa-times" class="text-danger"
                invisible="vendor_approval_state != 'pending'"/>
      </list>
    </field>
  </record>

  <!-- Form View with approval buttons -->
  <record id="view_vendor_product_approval_form" model="ir.ui.view">
    <field name="name">product.template.vendor.approval.form</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//header" position="inside">
        <button name="action_vendor_approve"
                string="✅ Approve &amp; Publish"
                type="object" class="oe_highlight"
                invisible="vendor_approval_state != 'pending' or not vendor_id"/>
        <button name="action_vendor_reject"
                string="❌ Reject"
                type="object"
                invisible="vendor_approval_state != 'pending' or not vendor_id"/>
        <button name="action_vendor_set_pending"
                string="↩ Reset to Pending"
                type="object"
                invisible="vendor_approval_state == 'pending' or not vendor_id"/>
        <field name="vendor_approval_state"
               widget="statusbar"
               statusbar_visible="pending,approved,rejected"
               invisible="not vendor_id"/>
      </xpath>
      <xpath expr="//sheet" position="before">
        <!-- Rejection notice banner -->
        <div class="alert alert-danger" role="alert"
             invisible="vendor_approval_state != 'rejected'">
          <strong>Rejected:</strong>
          <field name="vendor_rejection_reason" readonly="1" nolabel="1"/>
        </div>
      </xpath>
    </field>
  </record>

  <!-- Search for vendor products -->
  <record id="view_vendor_product_approval_search" model="ir.ui.view">
    <field name="name">product.template.vendor.approval.search</field>
    <field name="model">product.template</field>
    <field name="arch" type="xml">
      <search string="Vendor Products">
        <field name="name"/>
        <field name="vendor_id" string="Vendor"/>
        <filter string="Pending Review" name="pending"
                domain="[('vendor_approval_state','=','pending')]"/>
        <filter string="Approved" name="approved"
                domain="[('vendor_approval_state','=','approved')]"/>
        <filter string="Rejected" name="rejected"
                domain="[('vendor_approval_state','=','rejected')]"/>
        <filter string="Has Vendor" name="has_vendor"
                domain="[('vendor_id','!=',False)]"/>
        <separator/>
        <group expand="0" string="Group By">
          <filter string="Vendor" name="group_vendor"
                  context="{'group_by': 'vendor_id'}"/>
          <filter string="Status" name="group_state"
                  context="{'group_by': 'vendor_approval_state'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Action -->
  <record id="action_vendor_product_approval" model="ir.actions.act_window">
    <field name="name">Product Approvals</field>
    <field name="res_model">product.template</field>
    <field name="view_mode">list,form</field>
    <field name="view_id" ref="view_vendor_product_approval_list"/>
    <field name="search_view_id" ref="view_vendor_product_approval_search"/>
    <field name="domain">[('vendor_id','!=',False)]</field>
    <field name="context">{'search_default_pending': 1}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">No vendor products pending review</p>
    </field>
  </record>

</odoo>
