<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_wallet_form" model="ir.ui.view">
    <field name="name">uellow.vendor.wallet.form</field>
    <field name="model">uellow.vendor.wallet</field>
    <field name="arch" type="xml">
      <form string="Vendor Wallet">
        <sheet>
          <group>
            <group>
              <field name="vendor_id" readonly="1"/>
              <field name="currency_id"/>
              <field name="balance" readonly="1"/>
              <field name="pending_balance" readonly="1"/>
              <field name="total_earned" readonly="1"/>
            </group>
            <group>
              <field name="min_payout"/>
              <field name="payout_day"/>
            </group>
          </group>
          <field name="transaction_ids">
            <list>
              <field name="date"/>
              <field name="tx_type" widget="badge"
                     decoration-success="tx_type=='credit'"
                     decoration-danger="tx_type=='debit'"/>
              <field name="amount"/>
              <field name="description"/>
              <field name="state" widget="badge"/>
            </list>
          </field>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_vendor_wallets" model="ir.actions.act_window">
    <field name="name">Wallets</field>
    <field name="res_model">uellow.vendor.wallet</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
