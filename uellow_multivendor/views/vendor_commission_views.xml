<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_commission_plan_list" model="ir.ui.view">
    <field name="name">uellow.commission.plan.list</field>
    <field name="model">uellow.commission.plan</field>
    <field name="arch" type="xml">
      <list string="Commission Plans">
        <field name="name"/>
        <field name="code"/>
        <field name="monthly_fee"/>
        <field name="currency_id"/>
        <field name="commission_rate" string="Commission%"/>
        <field name="active" widget="boolean_toggle"/>
      </list>
    </field>
  </record>

  <record id="view_commission_plan_form" model="ir.ui.view">
    <field name="name">uellow.commission.plan.form</field>
    <field name="model">uellow.commission.plan</field>
    <field name="arch" type="xml">
      <form string="Commission Plan">
        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="active" widget="boolean_toggle"/>
            </group>
            <group>
              <field name="monthly_fee"/>
              <field name="currency_id"/>
              <field name="commission_rate"/>
            </group>
          </group>
          <field name="description" placeholder="Plan description..."/>
          <field name="category_commission_ids">
            <list editable="bottom">
              <field name="category_id"/>
              <field name="commission_rate" string="Commission%"/>
            </list>
          </field>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_commission_plans" model="ir.actions.act_window">
    <field name="name">Commission Plans</field>
    <field name="res_model">uellow.commission.plan</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_vendor_commission_list" model="ir.ui.view">
    <field name="name">uellow.vendor.commission.list</field>
    <field name="model">uellow.vendor.commission</field>
    <field name="arch" type="xml">
      <list string="Commissions" decoration-success="state=='paid'"
            decoration-warning="state=='hold'">
        <field name="vendor_id"/>
        <field name="order_id"/>
        <field name="order_date"/>
        <field name="order_amount"/>
        <field name="commission_rate" string="%"/>
        <field name="commission_amount"/>
        <field name="net_vendor_amount"/>
        <field name="currency_id"/>
        <field name="release_date"/>
        <field name="state" widget="badge"
               decoration-warning="state=='hold'"
               decoration-success="state in ('released','paid')"
               decoration-danger="state=='refunded'"/>
      </list>
    </field>
  </record>

  <record id="action_vendor_commissions" model="ir.actions.act_window">
    <field name="name">Commissions</field>
    <field name="res_model">uellow.vendor.commission</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_vendor_payout_list" model="ir.ui.view">
    <field name="name">uellow.vendor.payout.list</field>
    <field name="model">uellow.vendor.payout</field>
    <field name="arch" type="xml">
      <list string="Payouts" decoration-success="state=='paid'">
        <field name="name"/>
        <field name="vendor_id"/>
        <field name="amount"/>
        <field name="currency_id"/>
        <field name="payout_date"/>
        <field name="bank_iban"/>
        <field name="state" widget="badge"
               decoration-success="state=='paid'"
               decoration-info="state=='confirmed'"/>
      </list>
    </field>
  </record>

  <record id="view_vendor_payout_form" model="ir.ui.view">
    <field name="name">uellow.vendor.payout.form</field>
    <field name="model">uellow.vendor.payout</field>
    <field name="arch" type="xml">
      <form string="Vendor Payout">
        <header>
          <button name="action_confirm" string="Confirm"
                  type="object" class="oe_highlight"
                  invisible="state != 'draft'"/>
          <button name="action_mark_paid" string="Mark as Paid"
                  type="object" class="oe_highlight"
                  invisible="state != 'confirmed'"/>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="name" readonly="1"/>
              <field name="vendor_id"/>
              <field name="amount"/>
              <field name="currency_id" readonly="1"/>
            </group>
            <group>
              <field name="payout_date"/>
              <field name="bank_iban" readonly="1"/>
              <field name="bank_name" readonly="1"/>
            </group>
          </group>
          <field name="note"/>
          <field name="commission_line_ids">
            <list>
              <field name="order_id"/>
              <field name="order_date"/>
              <field name="net_vendor_amount"/>
              <field name="state" widget="badge"/>
            </list>
          </field>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_vendor_payouts" model="ir.actions.act_window">
    <field name="name">Payouts</field>
    <field name="res_model">uellow.vendor.payout</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
