<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════
         Apple Login - Standalone Settings Form
         No xpath inheritance = no fragility issues
         ════════════════════════════════════════════════════════════ -->

    <record id="view_apple_login_settings_form" model="ir.ui.view">
        <field name="name">apple.login.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Sign in with Apple — Settings" class="oe_form_configuration">
                <header>
                    <button string="Save" type="object" name="execute"
                            class="btn-primary" data-hotkey="s"/>
                    <button string="Discard" type="object" name="cancel"
                            special="cancel"/>
                </header>
                <sheet>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="apple_login_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="apple_login_enabled"
                                       string="Enable Sign in with Apple"/>
                                <div class="text-muted">
                                    Show the Apple login button on the login and signup pages.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div invisible="not apple_login_enabled">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <h4 class="mt0 mb16">Apple Developer Credentials</h4>

                                    <div class="row mb8">
                                        <label for="apple_login_client_id"
                                               class="col-lg-4 o_light_label"
                                               string="Client ID (Service ID)"/>
                                        <div class="col-lg-8">
                                            <field name="apple_login_client_id"
                                                   placeholder="com.uellow.signin"/>
                                        </div>
                                    </div>

                                    <div class="row mb8">
                                        <label for="apple_login_team_id"
                                               class="col-lg-4 o_light_label"
                                               string="Team ID"/>
                                        <div class="col-lg-8">
                                            <field name="apple_login_team_id"
                                                   placeholder="XXXXXXXXXX"/>
                                        </div>
                                    </div>

                                    <div class="row mb8">
                                        <label for="apple_login_key_id"
                                               class="col-lg-4 o_light_label"
                                               string="Key ID"/>
                                        <div class="col-lg-8">
                                            <field name="apple_login_key_id"
                                                   placeholder="XXXXXXXXXX"/>
                                        </div>
                                    </div>

                                    <div class="row mb8">
                                        <label for="apple_login_private_key"
                                               class="col-lg-4 o_light_label"
                                               string="Private Key (.p8)"/>
                                        <div class="col-lg-8">
                                            <field name="apple_login_private_key"
                                                   widget="text"
                                                   style="height:130px;font-family:monospace;font-size:11px;"
                                                   placeholder="-----BEGIN PRIVATE KEY-----&#10;...&#10;-----END PRIVATE KEY-----"/>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-12">
                                            <div class="alert alert-info mb-0" role="alert">
                                                <strong>Redirect URI</strong> — add this in Apple Developer Portal:<br/>
                                                <code>https://uellow.com/apple/login/callback</code>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_apple_login_settings" model="ir.actions.act_window">
        <field name="name">Sign in with Apple</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_apple_login_settings_form"/>
        <field name="target">inline</field>
        <field name="context">{'module': 'apple_login'}</field>
    </record>

    <!-- Root menu (no web_icon to avoid missing file error) -->
    <menuitem id="menu_apple_login_root"
              name="Apple Login"
              sequence="100"
              groups="base.group_system"/>

    <!-- Settings submenu -->
    <menuitem id="menu_apple_login_settings"
              name="Settings"
              parent="menu_apple_login_root"
              action="action_apple_login_settings"
              sequence="1"
              groups="base.group_system"/>

</odoo>
