<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="cron_detect_abandoned" model="ir.cron">
    <field name="name">Uellow: Detect Abandoned Carts</field>
    <field name="model_id" ref="model_uellow_abandoned_cart"/>
    <field name="state">code</field>
    <field name="code">model.cron_detect_abandoned()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">hours</field>
    <field name="active">True</field>
  </record>
  <record id="cron_send_recovery" model="ir.cron">
    <field name="name">Uellow: Send Cart Recovery Messages</field>
    <field name="model_id" ref="model_uellow_abandoned_cart"/>
    <field name="state">code</field>
    <field name="code">model.cron_send_recovery()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">hours</field>
    <field name="active">True</field>
  </record>
</odoo>
