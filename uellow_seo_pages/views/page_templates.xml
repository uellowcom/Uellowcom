<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="seo_landing_page" name="SEO Landing Page">
  <t t-call="website.layout">
    <div class="container py-5">
      <h1 class="fw-bold mb-2"><t t-esc="h1"/></h1>
      <p t-if="intro" class="lead text-muted mb-4"><t t-esc="intro"/></p>
      <div class="row g-3">
        <t t-foreach="products" t-as="product">
          <div class="col-6 col-md-3">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <h6 class="fw-bold"><t t-esc="product.name"/></h6>
                <div class="text-success fw-bold">
                  <t t-esc="'%.3f' % product.list_price"/> KD
                </div>
              </div>
              <div class="card-footer p-2">
                <a t-att-href="product.website_url" class="btn btn-sm btn-outline-primary w-100">View</a>
              </div>
            </div>
          </div>
        </t>
      </div>
      <div t-if="not products" class="text-center py-5 text-muted">No products available.</div>
    </div>
  </t>
</template>
</odoo>
