<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_seo_page_list" model="ir.ui.view">
    <field name="name">uellow.seo.page.list</field>
    <field name="model">uellow.seo.page</field>
    <field name="arch" type="xml">
      <list string="SEO Landing Pages">
        <field name="title_en"/><field name="title_ar"/>
        <field name="slug"/><field name="product_source"/>
        <field name="visit_count"/><field name="created_by_ai" widget="boolean"/>
        <field name="active" widget="boolean_toggle"/>
      </list>
    </field>
  </record>
  <record id="action_seo_pages" model="ir.actions.act_window">
    <field name="name">SEO Landing Pages</field>
    <field name="res_model">uellow.seo.page</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
