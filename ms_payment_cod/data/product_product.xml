<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="product_category_cod" model="product.category">
            <field name="parent_id" ref="product.product_category_all"/>
            <field name="name">Cash on Delivery</field>
        </record>

        <record id="product_product_cod" model="product.product">
            <field name="name">COD Fee</field>
            <field name="default_code">COD_001</field>
            <field name="type">service</field>
            <field name="categ_id" ref="ms_payment_cod.product_category_cod"/>
            <field name="sale_ok" eval="False"/>
            <field name="purchase_ok" eval="False"/>
            <field name="list_price">0.0</field>
            <field name="invoice_policy">order</field>
            <field name="taxes_id" eval="False"/>
        </record>

    </data>
</odoo>
