<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="method_form" inherit_id="payment.method_form">
            <xpath expr="//p[@name='o_payment_secured_by']" position="after">
                <div class="card bg-info" t-if="provider_sudo.custom_mode == 'cod'">
                    <div class="card-body">
                        <span>Warning: You have selected cash on delivery payment method, extra fee <span id="cod_fee_amount">0.0</span> will be added.</span>
                    </div>
                </div>
            </xpath>
        </template>

    </data>
</odoo>
