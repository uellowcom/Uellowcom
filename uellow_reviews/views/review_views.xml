<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_review_list" model="ir.ui.view">
    <field name="name">uellow.product.review.list</field>
    <field name="model">uellow.product.review</field>
    <field name="arch" type="xml">
      <list string="Reviews" decoration-warning="state=='pending'" decoration-success="state=='approved'">
        <field name="product_id"/><field name="partner_id"/>
        <field name="rating"/><field name="is_verified" widget="boolean"/>
        <field name="points_awarded"/><field name="helpful_count"/>
        <field name="state" widget="badge" decoration-warning="state=='pending'" decoration-success="state=='approved'" decoration-danger="state=='rejected'"/>
        <button name="action_approve" string="Approve" type="object" icon="fa-check" invisible="state!='pending'"/>
        <button name="action_reject" string="Reject" type="object" icon="fa-times" invisible="state!='pending'"/>
      </list>
    </field>
  </record>
  <record id="view_review_config_form" model="ir.ui.view">
    <field name="name">uellow.review.config.form</field>
    <field name="model">uellow.review.config</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <group><field name="active" widget="boolean_toggle"/><field name="require_purchase"/><field name="auto_approve"/><field name="moderation_required"/></group>
            <group string="Points"><field name="points_text"/><field name="points_photo"/><field name="points_video"/></group>
          </group>
        </sheet>
      </form>
    </field>
  </record>
  <record id="action_reviews" model="ir.actions.act_window">
    <field name="name">Product Reviews</field><field name="res_model">uellow.product.review</field><field name="view_mode">list,form</field>
    <field name="context">{'search_default_pending': 1}</field>
  </record>
  <record id="action_review_config" model="ir.actions.act_window">
    <field name="name">Review Settings</field><field name="res_model">uellow.review.config</field><field name="view_mode">form</field>
  </record>
</odoo>
