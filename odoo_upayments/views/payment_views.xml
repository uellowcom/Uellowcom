<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payment provider form view inherit -->
    <record id="payment_provider_form_upayments" model="ir.ui.view">
        <field name="name">UPayments provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position='inside'>
                <group invisible="code != 'upayments'">
                    <field name="upay_application_key" password="True"
                           required="code != 'upayments' and state != 'disabled'"/>
                    <field name="api_type" invisible="1"/>
                </group>
            </group>
            <xpath expr="//page[@name='messages']//field[@name='cancel_msg']" position="after">
                <field name="error_msg"/>
            </xpath>
        </field>
    </record>

</odoo>

