<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="account_payment_method_upayments" model="account.payment.method">
        <field name="name">UPayments</field>
        <field name="code">upayments</field>
        <field name="payment_type">inbound</field>
    </record>

    <record id="payment_provider_upayments" model="payment.provider">
        <field name="name">UPayments</field>
        <field name="code">upayments</field>
        <field name="image_128" type="base64" file="odoo_upayments/static/description/icon.png"/>
        <field name="payment_method_ids"
               eval="[Command.set([ref('odoo_upayments.payment_method_upayments')])]"
        />
        <field name="allow_express_checkout">True</field>
        <field name="allow_tokenization">True</field>
        <field name="support_refund">partial</field>
        <field name="module_id" ref="base.module_odoo_upayments"/>
        <field name="redirect_form_view_id" ref="odoo_upayments.redirect_form"/>
    </record>

</odoo>
