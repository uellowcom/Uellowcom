<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Quick Checkout Form Template -->
    <t t-name="quick_checkout.QuickCheckoutFormTemplate" owl="1">
        <form t-ref="checkoutForm" class="quick_checkout_form" t-on-submit="onSubmitForm" action="/shop/quick_checkout/submit" method="post">
            <input type="hidden" name="csrf_token" t-att-value="csrf_token"/>
            <div class="form-group mb-3">
                <label for="name">Name</label>
                <input type="text" name="name" class="form-control" required="required"/>
            </div>
            <div class="form-group mb-3">
                <label for="phone">Phone</label>
                <input type="tel" name="phone" class="form-control" required="required"/>
            </div>
            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary w-100" t-att-disabled="state.isSubmitting">
                    <t t-if="state.isSubmitting">
                        <i class="fa fa-spinner fa-spin"/> Processing...
                    </t>
                    <t t-else="">
                        Complete Quick Checkout
                    </t>
                </button>
            </div>
        </form>
    </t>

    <!-- Product Quick Checkout Button Template -->
    <t t-name="quick_checkout.ProductQuickCheckoutButtonTemplate" owl="1">
        <a t-att-href="'/shop/product/quick_checkout/' + productId" 
           class="btn btn-secondary w-100"
           t-on-click="onClickQuickCheckout"
           t-att-disabled="state.isLoading">
            <t t-if="state.isLoading">
                <i class="fa fa-spinner fa-spin"/> Processing...
            </t>
            <t t-else="">
                <i class="fa fa-bolt"/> Quick Checkout
            </t>
        </a>
    </t>

    <!-- Theme Prime Compatibility Fix Template -->
    <t t-name="quick_checkout.ThemePrimeQuickCheckoutFixTemplate" owl="1">
        <!-- Empty template, just used for the component lifecycle -->
        <t t-if="false">Theme Prime Fix</t>
    </t>
</templates>
