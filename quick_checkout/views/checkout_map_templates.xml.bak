<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Direct injection of map into checkout form -->
    <template id="checkout_map_injection" inherit_id="website_sale.address" active="True">
        <xpath expr="//div[hasclass('o_checkout_addresses')]" position="before">
            <div class="row mt-3 mb-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Pinpoint Your Location on Map</h5>
                        </div>
                        <div class="card-body">
                            <!-- Map container -->
                            <div id="checkout-map-container" class="mb-3" style="height: 300px; border-radius: 8px;"></div>
                            
                            <!-- Location details -->
                            <div id="location-details" class="mt-3" style="display: none;">
                                <p class="mb-1"><strong>Selected Location:</strong></p>
                                <p id="location-address" class="mb-2"></p>
                                <p id="location-coordinates" class="small text-muted"></p>
                            </div>
                            
                            <!-- Controls -->
                            <div class="mt-2">
                                <button type="button" id="get-current-location" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa fa-location-arrow me-1"></i> Use My Current Location
                                </button>
                                <small class="text-muted ms-3">
                                    <i class="fa fa-info-circle me-1"></i> Drag the marker to pinpoint your exact location
                                </small>
                            </div>
                            
                            <!-- Hidden fields for location data -->
                            <input type="hidden" id="latitude" name="latitude" />
                            <input type="hidden" id="longitude" name="longitude" />
                            <input type="hidden" id="map_address" name="map_address" />
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Load Leaflet resources and initialize map -->
            <script type="text/javascript">
                odoo.define('quick_checkout.checkout_map_direct', function (require) {
                    'use strict';
                    
                    // Wait for document to be ready
                    $(document).ready(function() {
                        // Load Leaflet CSS
                        if (!document.getElementById('leaflet-css')) {
                            const linkElement = document.createElement('link');
                            linkElement.id = 'leaflet-css';
                            linkElement.rel = 'stylesheet';
                            linkElement.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
                            document.head.appendChild(linkElement);
                        }
                        
                        // Load Leaflet JS
                        if (!window.L) {
                            const scriptElement = document.createElement('script');
                            scriptElement.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
                            scriptElement.onload = initializeMap;
                            document.head.appendChild(scriptElement);
                        } else {
                            initializeMap();
                        }
                        
                        // Initialize map
                        function initializeMap() {
                            const mapContainer = document.getElementById('checkout-map-container');
                            if (!mapContainer) return;
                            
                            // Default location (Riyadh)
                            const defaultLat = 24.7136;
                            const defaultLng = 46.6753;
                            
                            // Create map
                            const map = L.map('checkout-map-container').setView([defaultLat, defaultLng], 13);
                            
                            // Add OpenStreetMap tiles
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '&amp;copy; &lt;a href="https://www.openstreetmap.org/copyright"&gt;OpenStreetMap&lt;/a&gt; contributors'
                            }).addTo(map);
                            
                            // Add a marker that can be dragged
                            const marker = L.marker([defaultLat, defaultLng], {
                                draggable: true
                            }).addTo(map);
                            
                            // Update location when marker is dragged
                            marker.on('dragend', function(event) {
                                const position = marker.getLatLng();
                                updateLocationData(position.lat, position.lng);
                                reverseGeocode(position.lat, position.lng);
                            });
                            
                            // Get current location button
                            document.getElementById('get-current-location').addEventListener('click', function() {
                                if (navigator.geolocation) {
                                    navigator.geolocation.getCurrentPosition(
                                        function(position) {
                                            const { latitude, longitude } = position.coords;
                                            map.setView([latitude, longitude], 15);
                                            marker.setLatLng([latitude, longitude]);
                                            updateLocationData(latitude, longitude);
                                            reverseGeocode(latitude, longitude);
                                        },
                                        function(error) {
                                            console.error('Geolocation error:', error);
                                            alert('Could not get your location. Please try again or manually position the marker.');
                                        },
                                        { enableHighAccuracy: true }
                                    );
                                } else {
                                    alert('Geolocation is not supported by your browser');
                                }
                            });
                            
                            // Try to get user's current location on load
                            if (navigator.geolocation) {
                                navigator.geolocation.getCurrentPosition(
                                    function(position) {
                                        const { latitude, longitude } = position.coords;
                                        map.setView([latitude, longitude], 15);
                                        marker.setLatLng([latitude, longitude]);
                                        updateLocationData(latitude, longitude);
                                        reverseGeocode(latitude, longitude);
                                    },
                                    function(error) {
                                        console.error('Geolocation error:', error);
                                        // Continue with default location
                                    },
                                    { enableHighAccuracy: true }
                                );
                            }
                            
                            // Update hidden form fields with location data
                            function updateLocationData(latitude, longitude) {
                                document.getElementById('latitude').value = latitude;
                                document.getElementById('longitude').value = longitude;
                                
                                // Update coordinates display
                                const coordsElement = document.getElementById('location-coordinates');
                                if (coordsElement) {
                                    coordsElement.innerHTML = '<i class="fa fa-crosshairs me-1"></i> Lat: ' + 
                                        latitude.toFixed(6) + ', Lng: ' + longitude.toFixed(6);
                                }
                                
                                // Show location details
                                document.getElementById('location-details').style.display = 'block';
                            }
                            
                            // Get address from coordinates using OpenStreetMap Nominatim
                            function reverseGeocode(latitude, longitude) {
                                fetch('https://nominatim.openstreetmap.org/reverse?format=json&amp;lat=' + 
                                      latitude + '&amp;lon=' + longitude + '&amp;zoom=18&amp;addressdetails=1')
                                    .then(function(response) { return response.json(); })
                                    .then(function(data) {
                                        if (data && data.display_name) {
                                            // Update address field
                                            document.getElementById('map_address').value = data.display_name;
                                            
                                            // Update address display
                                            const addressElement = document.getElementById('location-address');
                                            if (addressElement) {
                                                addressElement.innerHTML = '<i class="fa fa-map-marker me-2"></i>' + data.display_name;
                                            }
                                            
                                            // Populate address form fields
                                            populateAddressFields(data);
                                        }
                                    })
                                    .catch(function(error) {
                                        console.error('Reverse geocoding error:', error);
                                    });
                            }
                            
                            // Populate address form fields from Nominatim data
                            function populateAddressFields(data) {
                                if (!data || !data.address) return;
                                
                                const address = data.address;
                                
                                // Map Nominatim fields to form fields
                                const fieldMappings = {
                                    'street': ['road', 'street', 'street_name'],
                                    'street2': ['suburb', 'neighbourhood', 'building'],
                                    'city': ['city', 'town', 'village', 'county'],
                                    'zip': ['postcode'],
                                    'state_id': ['state', 'province', 'state_district'],
                                    'country_id': ['country', 'country_code']
                                };
                                
                                // Find form fields
                                for (const formField in fieldMappings) {
                                    const possibleFields = fieldMappings[formField];
                                    
                                    // Try to find an input with this name or id
                                    let input = document.querySelector('input[name="' + formField + '"], #' + formField);
                                    
                                    if (input) {
                                        // Try each possible field from Nominatim
                                        for (const nominatimField of possibleFields) {
                                            if (address[nominatimField]) {
                                                input.value = address[nominatimField];
                                                break;
                                            }
                                        }
                                    }
                                }
                                
                                // Handle special case for country and state selects
                                const countrySelect = document.querySelector('select[name="country_id"]');
                                if (countrySelect && address.country_code) {
                                    // Find option with matching country code or name
                                    const countryCode = address.country_code.toUpperCase();
                                    const countryOptions = countrySelect.querySelectorAll('option');
                                    
                                    for (const option of countryOptions) {
                                        if (option.text.includes(countryCode) 
                                            || option.text.toLowerCase().includes(address.country.toLowerCase())) {
                                            countrySelect.value = option.value;
                                            // Trigger change event to update state dropdown
                                            countrySelect.dispatchEvent(new Event('change'));
                                            break;
                                        }
                                    }
                                }
                                
                                // Wait a bit for state dropdown to be populated if country changed
                                setTimeout(function() {
                                    const stateSelect = document.querySelector('select[name="state_id"]');
                                    if (stateSelect && address.state) {
                                        const stateOptions = stateSelect.querySelectorAll('option');
                                        
                                        for (const option of stateOptions) {
                                            if (option.text.toLowerCase().includes(address.state.toLowerCase())) {
                                                stateSelect.value = option.value;
                                                break;
                                            }
                                        }
                                    }
                                }, 500);
                            }
                            }
                        }
                    });
                });
            </script>
        </xpath>
    </template>
</odoo>
