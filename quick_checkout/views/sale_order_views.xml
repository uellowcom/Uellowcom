<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Quick Checkout field to Sale Order form view -->
    <record id="view_order_form_inherit_quick_checkout" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.quick.checkout</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_quick_checkout" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Add Quick Checkout filter to Sale Order search view -->
    <record id="view_sales_order_filter_inherit_quick_checkout" model="ir.ui.view">
        <field name="name">sale.order.list.select.inherit.quick.checkout</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_sale_orders_filter']" position="after">
                <filter string="Quick Checkout Orders" name="quick_checkout_orders" domain="[('is_quick_checkout', '=', True)]"/>
            </xpath>
        </field>
    </record>
</odoo>
