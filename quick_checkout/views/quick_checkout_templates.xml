<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quick Checkout Form Template -->
    <template id="quick_checkout_form" name="Quick Checkout Form">
        <t t-call="website.layout">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-lg-6 offset-lg-3">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h3 class="mb-0">Quick Checkout</h3>
                            </div>
                            <div class="card-body">
                                <form id="quick_checkout_form" action="/shop/quick_checkout/submit" method="post" class="quick_checkout_form">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="form-group mb-3">
                                        <label for="name">Name</label>
                                        <input type="text" name="name" class="form-control" required="required"/>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label for="phone">Phone</label>
                                        <input type="tel" name="phone" class="form-control" required="required"/>
                                    </div>
                                    
                                    <!-- Location Map Section -->
                                    <div class="form-group mb-3">
                                        <label for="address">Your Location</label>
                                        <div class="map-component-container">
                                            <div t-att-data-component-name="'map_location'" class="o_frontend_component"></div>
                                        </div>
                                        <!-- Hidden fields to store location data -->
                                        <input type="hidden" id="latitude" name="latitude" />
                                        <input type="hidden" id="longitude" name="longitude" />
                                        <input type="hidden" id="address" name="address" />
                                    </div>
                                    
                                    <div class="form-group mt-4">
                                        <button type="submit" class="btn btn-primary w-100">Complete Quick Checkout</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Quick Checkout Success Template -->
    <template id="quick_checkout_success" name="Quick Checkout Success">
        <t t-call="website.layout">
            <div class="container mt-4">
                <div class="alert alert-success">
                    <h3>Thank you for your order!</h3>
                    <p>Your order has been received and is being processed.</p>
                    <p>We will contact you shortly at <t t-esc="phone"/> to confirm your order.</p>
                    <t t-if="address">
                        <p class="mt-2"><strong>Delivery Address:</strong></p>
                        <p><i class="fa fa-map-marker me-2"></i><t t-esc="address"/></p>
                    </t>
                    <a href="/shop" class="btn btn-primary mt-3">Continue Shopping</a>
                </div>
            </div>
        </t>
    </template>
    
    <!-- Add Quick Checkout Button to Product Page -->
    <template id="product_quick_checkout_button" inherit_id="website_sale.product" active="True" customize_show="True" name="Quick Checkout Button">
        <xpath expr="//div[@id='add_to_cart_wrap']" position="after">
            <div class="mt-2">
                <a t-att-href="'/shop/product/quick_checkout/%s' % product.id" class="btn btn-secondary w-100">
                    <i class="fa fa-bolt"/> Quick Checkout
                </a>
            </div>
        </xpath>
    </template>
</odoo>
