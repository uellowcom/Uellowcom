<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_price_check" model="ir.cron">
        <field name="name">Smart Connector: فحص أسعار المنافسين</field>
        <field name="model_id" ref="model_uellow_price_intelligence"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_prices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
    <record id="cron_dead_stock" model="ir.cron">
        <field name="name">Smart Connector: فحص المخزون الراكد</field>
        <field name="model_id" ref="model_uellow_dead_stock"/>
        <field name="state">code</field>
        <field name="code">model.cron_scan_dead_stock()</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
