<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_price_intel_list" model="ir.ui.view">
    <field name="name">uellow.price.intelligence.list</field>
    <field name="model">uellow.price.intelligence</field>
    <field name="arch" type="xml">
      <list string="Price Intelligence"
            decoration-danger="state=='pricier'"
            decoration-success="state=='cheaper'"
            decoration-muted="state=='error'">
        <field name="product_id" string="Product"/>
        <field name="source_name" string="Competitor"/>
        <field name="our_price" string="Our Price (KD)"/>
        <field name="competitor_price" string="Competitor Price (KD)"/>
        <field name="price_diff_pct" string="Difference (%)"/>
        <field name="last_checked" string="Last Checked"/>
        <field name="state" widget="badge"
               decoration-danger="state=='pricier'"
               decoration-success="state=='cheaper'"
               decoration-warning="state=='error'"/>
      </list>
    </field>
  </record>

  <record id="view_price_intel_form" model="ir.ui.view">
    <field name="name">uellow.price.intelligence.form</field>
    <field name="model">uellow.price.intelligence</field>
    <field name="arch" type="xml">
      <form string="Price Monitor">
        <sheet>
          <group>
            <group string="Product">
              <field name="product_id" string="Product"/>
              <field name="our_price" readonly="1" string="Our Price (KD)"/>
            </group>
            <group string="Competitor">
              <field name="source_name" string="Competitor Name"/>
              <field name="source_url" string="Competitor URL" widget="url"/>
              <field name="competitor_price" readonly="1" string="Competitor Price (KD)"/>
              <field name="price_diff_pct" readonly="1" string="Price Difference (%)"/>
            </group>
          </group>
          <group>
            <field name="last_checked" readonly="1" string="Last Checked"/>
            <field name="state" readonly="1" widget="badge" string="Status"/>
            <field name="alert_sent" readonly="1" string="Alert Sent"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_price_intel_search" model="ir.ui.view">
    <field name="name">uellow.price.intelligence.search</field>
    <field name="model">uellow.price.intelligence</field>
    <field name="arch" type="xml">
      <search string="Search Price Monitor">
        <field name="product_id" string="Product"/>
        <field name="source_name" string="Competitor"/>
        <filter string="We're More Expensive" name="pricier"
                domain="[('state','=','pricier')]"/>
        <filter string="We're Cheaper" name="cheaper"
                domain="[('state','=','cheaper')]"/>
        <filter string="Errors" name="error"
                domain="[('state','=','error')]"/>
      </search>
    </field>
  </record>

  <record id="action_price_intel" model="ir.actions.act_window">
    <field name="name">Price Intelligence</field>
    <field name="res_model">uellow.price.intelligence</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_price_intel_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">No prices monitored yet</p>
      <p>Add products to monitor against competitor prices.</p>
    </field>
  </record>

</odoo>
