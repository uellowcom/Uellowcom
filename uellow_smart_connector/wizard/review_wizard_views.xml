<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_review_wizard_form" model="ir.ui.view">
    <field name="name">uellow.import.review.wizard.form</field>
    <field name="model">uellow.import.review.wizard</field>
    <field name="arch" type="xml">
      <form string="مراجعة نتائج الاستيراد">
        <sheet>
          <div class="o_field_widget oe_button_box">
            <button class="oe_stat_button" icon="fa-list" type="object"
                    name="action_open_lines">
              <field name="line_count" widget="statinfo" string="سطر"/>
            </button>
            <button class="oe_stat_button" icon="fa-exclamation-triangle">
              <field name="warning_count" widget="statinfo" string="تحذير"/>
            </button>
            <button class="oe_stat_button" icon="fa-plus">
              <field name="new_count" widget="statinfo" string="جديد"/>
            </button>
            <button class="oe_stat_button" icon="fa-refresh">
              <field name="update_count" widget="statinfo" string="تحديث"/>
            </button>
          </div>
          <group>
            <field name="job_id" readonly="1"/>
            <field name="filter_type"/>
          </group>
          <group string="خيارات الاعتماد السريع">
            <field name="approve_all"/>
            <field name="reject_warnings"/>
          </group>
        </sheet>
        <footer>
          <button name="action_apply_review" string="تطبيق وإغلاق"
                  type="object" class="oe_highlight"/>
          <button name="action_open_lines" string="مراجعة يدوية"
                  type="object"/>
          <button string="إلغاء" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
