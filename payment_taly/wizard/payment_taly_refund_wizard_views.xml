<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_taly_refund_wizard_form" model="ir.ui.view">
        <field name="name">payment.taly.refund.wizard.form</field>
        <field name="model">payment.taly.refund.wizard</field>
        <field name="arch" type="xml">
            <form string="Request Taly Refund">
                <div class="alert alert-warning mb-3" role="alert">
                    <strong>⚠️ تأكيد طلب الاسترداد</strong><br/>
                    سيتم إرسال طلب الاسترداد إلى Taly. هذا الإجراء لا يمكن التراجع عنه.
                </div>
                <group>
                    <group string="Transaction Details">
                        <field name="transaction_id" readonly="1"/>
                        <field name="max_amount" readonly="1" string="Max Refundable"/>
                        <field name="currency_id" readonly="1"/>
                    </group>
                    <group string="Refund Request">
                        <field name="amount" required="1"/>
                        <field name="reason" required="1"
                               placeholder="e.g. Customer request, wrong order..."/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm_refund"
                            string="✅ Confirm Refund"
                            type="object"
                            class="btn btn-warning"/>
                    <button string="Cancel"
                            class="btn btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
