<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Taly Checkout Redirect Page (standalone - no inherit)
         ============================================================ -->
    <record id="taly_redirect_page" model="ir.ui.view">
        <field name="name">taly_redirect_page</field>
        <field name="type">qweb</field>
        <field name="key">payment_taly.taly_redirect_page</field>
        <field name="arch" type="xml">
            <t t-name="payment_taly.taly_redirect_page">
                <t t-call="website.layout">
                    <div class="container d-flex align-items-center justify-content-center"
                         style="min-height:70vh; direction:rtl;">
                        <div class="text-center p-5 rounded shadow"
                             style="background:white; max-width:480px; width:100%;">
                            <div class="mb-4 mx-auto d-flex align-items-center justify-content-center"
                                 style="width:80px;height:80px;border-radius:50%;
                                        background:linear-gradient(135deg,#7B2FF7,#00C9A7);
                                        font-size:2rem;color:white;">
                                &#x1F4B3;
                            </div>
                            <h3 class="mb-3">اكتمال الدفع مع تالي</h3>
                            <p class="text-muted">
                                سيتم تحويلك الآن لإتمام عملية الدفع بالأقساط عبر بوابة تالي الآمنة.
                            </p>
                            <style>@keyframes taly-spin{to{transform:rotate(360deg)}}</style>
                            <div class="my-3 mx-auto"
                                 style="border:3px solid #f3f3f3;border-top:3px solid #7B2FF7;
                                        border-radius:50%;width:32px;height:32px;
                                        animation:taly-spin .8s linear infinite;"/>
                            <p class="text-muted small mb-3">جارٍ التحويل...</p>
                            <a t-att-href="checkout_url"
                               class="btn btn-lg text-white"
                               style="background:linear-gradient(135deg,#7B2FF7,#00C9A7);">
                                أكمل الدفع مع تالي &#x2190;
                            </a>
                            <div class="mt-3">
                                <small class="text-muted">
                                    &#x1F512; دفع آمن ومشفر · بدون فوائد · متوافق مع الشريعة الإسلامية
                                </small>
                            </div>
                            <t t-if="checkout_url">
                                <script t-att-data-url="checkout_url">
                                    setTimeout(function(){
                                        var s = document.querySelector('script[data-url]');
                                        var u = s &amp;&amp; s.getAttribute('data-url');
                                        if(u) window.location.href = u;
                                    }, 1500);
                                </script>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <!-- ============================================================
         Product Widget - DISABLED at install, activated after finding
         correct xpath via: Settings > Technical > User Interface > Views
         Search: "website_sale.product" to find correct xpath target
         ============================================================ -->
    <record id="taly_product_widget" model="ir.ui.view">
        <field name="name">Taly Installment Widget</field>
        <field name="type">qweb</field>
        <field name="key">payment_taly.taly_product_widget</field>
        <field name="inherit_id" ref="website_sale.product"/>
        <field name="active">False</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='product_detail']" position="before">
                <t t-set="taly_provider"
                   t-value="request.env['payment.provider'].sudo().search(
                       [('code','=','taly'),('state','in',['enabled','test'])], limit=1)"/>
                <t t-if="taly_provider and taly_provider.taly_show_widget_product">
                    <div class="taly-product-widget container mb-2"
                         t-att-data-price="product.list_price"
                         t-att-data-installment-type="taly_provider.taly_installment_type or '3'"
                         t-att-data-lang="taly_provider.taly_widget_lang or 'ar'">
                        <div class="d-flex align-items-center gap-2 p-2"
                             style="background:#f8f0ff;border-radius:8px;
                                    border:1px solid #e8d5ff;cursor:pointer;"
                             data-bs-toggle="modal"
                             data-bs-target="#talyWidgetModal">
                            <span style="font-size:1.1rem;">&#x1F4B3;</span>
                            <span class="text-muted small">
                                قسّم على
                                <strong>
                                    <t t-esc="taly_provider.taly_installment_type or '3'"/>
                                </strong>
                                دفعات بدون فوائد ·
                                <span style="color:#7B2FF7;font-weight:600;">تعرف على المزيد</span>
                            </span>
                        </div>
                    </div>
                    <div class="modal fade" id="talyWidgetModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header"
                                     style="background:linear-gradient(135deg,#7B2FF7,#00C9A7);color:white;">
                                    <h5 class="modal-title">&#x1F4B3; خيارات الدفع مع تالي</h5>
                                    <button type="button" class="btn-close btn-close-white"
                                            data-bs-dismiss="modal"/>
                                </div>
                                <div class="modal-body p-0">
                                    <t t-set="widget_src"
                                       t-value="'https://promo.taly.io/installment-widget?price=%s&amp;installmenttype=%s&amp;lang=%s' % (
                                           product.list_price,
                                           taly_provider.taly_installment_type or '3',
                                           taly_provider.taly_widget_lang or 'ar'
                                       )"/>
                                    <iframe t-att-src="widget_src"
                                            width="100%"
                                            style="border:none;min-height:500px;"
                                            loading="lazy"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </xpath>
        </field>
    </record>

</odoo>
