<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="checkout_map.CheckoutMapComponentTemplate" owl="1">
        <div class="checkout-map-wrapper">
            <div t-ref="mapContainer" class="mb-3" style="height: 300px; border-radius: 8px;"></div>
            
            <!-- Location details -->
            <div class="mt-3" t-if="state.location.address" style="display: block;">
                <p class="mb-1"><strong>Selected Location:</strong></p>
                <p class="mb-2"><t t-esc="state.location.address"/></p>
                <p class="small text-muted">
                    Coordinates: <t t-esc="state.location.latitude"/>, <t t-esc="state.location.longitude"/>
                </p>
            </div>
            
            <!-- Controls -->
            <div class="mt-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="onRefreshLocation">
                    <i class="fa fa-location-arrow me-1"></i> Use My Current Location
                </button>
                <small class="text-muted ms-3">
                    <i class="fa fa-info-circle me-1"></i> Drag the marker to pinpoint your exact location
                </small>
            </div>
            
            <!-- Error message -->
            <div class="alert alert-warning mt-2" t-if="state.error">
                <i class="fa fa-exclamation-triangle me-1"></i>
                <t t-esc="state.error"/>
            </div>
        </div>
    </t>
    
    <t t-name="checkout_map.CheckoutMapInjectorTemplate" owl="1">
        <!-- This is just a placeholder for the injector component -->
        <div class="checkout-map-injector"></div>
    </t>
</templates>
