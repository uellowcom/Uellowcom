<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Direct injection of map into checkout form -->
    <template id="checkout_map_injection" inherit_id="website_sale.checkout" active="True">
        <xpath expr="//div[@id='shop_checkout']" position="inside">
            <div class="row mt-3 mb-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Pinpoint Your Location on Map</h5>
                        </div>
                        <div class="card-body">
                            <!-- Map container -->
                            <div id="checkout-map-container" class="mb-3" style="height: 300px; border-radius: 8px;"></div>
                            
                            <!-- Location details -->
                            <div id="location-details" class="mt-3" style="display: none;">
                                <p class="mb-1"><strong>Selected Location:</strong></p>
                                <p id="location-address" class="mb-2"></p>
                                <p id="location-coordinates" class="small text-muted"></p>
                            </div>
                            
                            <!-- Controls -->
                            <div class="mt-2">
                                <button type="button" id="get-current-location" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa fa-location-arrow me-1"></i> Use My Current Location
                                </button>
                                <small class="text-muted ms-3">
                                    <i class="fa fa-info-circle me-1"></i> Drag the marker to pinpoint your exact location
                                </small>
                            </div>
                            
                            <!-- Hidden fields for location data -->
                            <input type="hidden" id="latitude" name="latitude" />
                            <input type="hidden" id="longitude" name="longitude" />
                            <input type="hidden" id="map_address" name="map_address" />
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Mount Owl component for map -->
            <div id="checkout-map-component" class="mb-3"></div>
        </xpath>
    </template>
</odoo>
