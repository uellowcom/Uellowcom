<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_chat_session_list" model="ir.ui.view">
        <field name="name">ai.chat.session.list</field>
        <field name="model">ai.chat.session</field>
        <field name="arch" type="xml">
            <list string="محادثات Beena" default_order="write_date desc">
                <field name="session_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="last_state"/>
                <field name="write_date" string="آخر نشاط"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_chat_session_form" model="ir.ui.view">
        <field name="name">ai.chat.session.form</field>
        <field name="model">ai.chat.session</field>
        <field name="arch" type="xml">
            <form string="محادثة Beena">
                <sheet>
                    <group>
                        <field name="session_id" readonly="1"/>
                        <field name="partner_id"/>
                        <field name="product_id"/>
                        <field name="last_state"/>
                        <field name="active"/>
                    </group>
                    <group string="سجل المحادثة (JSON)">
                        <field name="messages_json" widget="text" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_chat_sessions" model="ir.actions.act_window">
        <field name="name">محادثات Beena</field>
        <field name="res_model">ai.chat.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ai_root"
              name="🐝 Beena AI"
              sequence="90"
              groups="base.group_system"/>

    <menuitem id="menu_ai_sessions"
              name="المحادثات"
              parent="menu_ai_root"
              action="action_ai_chat_sessions"
              sequence="10"/>
</odoo>
