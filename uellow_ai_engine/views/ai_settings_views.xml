<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_config_settings" model="ir.ui.view">
        <field name="name">ai.config.settings.form</field>
        <field name="model">ai.config.settings</field>
        <field name="arch" type="xml">
            <form string="Beena AI Settings">
                <header>
                    <button string="حفظ التغييرات" type="object" name="execute" class="btn-primary"/>
                    <button string="إلغاء" type="object" name="cancel" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="o_setting_container">
                        <div class="o_settings_header">
                            <h1>Beena AI Engine</h1>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_enabled" widget="boolean_toggle"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_enabled" string="تفعيل Beena"/>
                                <div class="text-muted">تشغيل/إيقاف المساعد على الموقع</div>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_assistant_name" string="اسم المساعد"/>
                                <field name="ai_assistant_name"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_assistant_subtitle" string="العنوان التوضيحي"/>
                                <field name="ai_assistant_subtitle"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_welcome_message" string="رسالة الترحيب"/>
                                <field name="ai_welcome_message"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_button_color" string="لون الزر (Hex)"/>
                                <field name="ai_button_color"/>
                                <div class="text-muted">مثال: #F5C320</div>
                            </div>
                        </div>

                        <div class="o_settings_header">
                            <h2>Claude API</h2>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_claude_api_key" string="Claude API Key"/>
                                <field name="ai_claude_api_key" password="True"/>
                                <div class="text-muted">من console.anthropic.com</div>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_claude_model" string="نموذج Claude"/>
                                <field name="ai_claude_model"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_max_tokens" string="Max Tokens"/>
                                <field name="ai_max_tokens"/>
                            </div>
                        </div>

                        <div class="o_settings_header">
                            <h2>السلوك</h2>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_float_button" widget="boolean_toggle"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_float_button" string="زر Float في كل الصفحات"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_buy_with_ai" widget="boolean_toggle"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_buy_with_ai" string="زر Buy with AI"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_proactive_nudge" widget="boolean_toggle"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_proactive_nudge" string="Proactive Nudge"/>
                                <div class="text-muted">Beena تظهر تلقائياً بعد فترة تصفح</div>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_nudge_delay" string="تأخير Nudge (ثانية)"/>
                                <field name="ai_nudge_delay"/>
                            </div>
                        </div>

                        <div class="o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_default_language" string="لغة الرد"/>
                                <field name="ai_default_language"/>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_config_settings" model="ir.actions.act_window">
        <field name="name">إعدادات Beena AI</field>
        <field name="res_model">ai.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="view_ai_chat_session_list" model="ir.ui.view">
        <field name="name">ai.chat.session.list</field>
        <field name="model">ai.chat.session</field>
        <field name="arch" type="xml">
            <list string="محادثات Beena" default_order="write_date desc">
                <field name="session_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="last_state"/>
                <field name="write_date" string="آخر نشاط"/>
            </list>
        </field>
    </record>

    <record id="action_ai_chat_sessions" model="ir.actions.act_window">
        <field name="name">محادثات Beena</field>
        <field name="res_model">ai.chat.session</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_ai_root"
              name="Beena AI"
              sequence="90"
              groups="base.group_system"/>

    <menuitem id="menu_ai_sessions"
              name="المحادثات"
              parent="menu_ai_root"
              action="action_ai_chat_sessions"
              sequence="10"/>

    <menuitem id="menu_ai_settings"
              name="الاعدادات"
              parent="menu_ai_root"
              action="action_ai_config_settings"
              sequence="20"/>
</odoo>
