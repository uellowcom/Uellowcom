<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_cancel']" position="before">
                <button name="print_delivery_label" string="Print Label" type="object"
                        invisible="state not in ('assigned', 'done')"
                        groups="stock.group_stock_user"
                        class="oe_highlight"/>
            </xpath>
            <!-- Add Payment Method + COD Amount in Additional Info tab -->
            <xpath expr="//page[@name='extra']" position="inside">
                <group string="Payment">
                    <field name="payment_method" widget="radio" readonly="0"/>
                    <field name="cod_amount"
                           readonly="0"
                           invisible="payment_method != 'cod'"
                           required="payment_method == 'cod'"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
