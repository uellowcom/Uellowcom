<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit delivery.carrier form view to add logo field -->
    <record id="view_delivery_carrier_form_inherit" model="ir.ui.view">
        <field name="name">delivery.carrier.form.inherit</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="logo" widget="image" class="oe_avatar"/>
            </xpath>
            <xpath expr="//field[@name='delivery_type']" position="after">
                <field name="vendor_partner_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit delivery.carrier tree view to add logo field -->
    <record id="view_delivery_carrier_tree_inherit" model="ir.ui.view">
        <field name="name">delivery.carrier.tree.inherit</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="logo" widget="image" class="oe_avatar" options="{'size': [30, 30]}"/>
            </xpath>
            <xpath expr="//field[@name='delivery_type']" position="after">
                <field name="vendor_partner_id"/>
            </xpath>
        </field>
    </record>

    <!-- Action to open delivery carrier form -->
    <record id="action_delivery_carrier_form" model="ir.actions.act_window">
        <field name="name">Delivery Carriers</field>
        <field name="res_model">delivery.carrier</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="delivery.view_delivery_carrier_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new delivery carrier
            </p>
            <p>
                Define the delivery carriers you are working with and set up their pricing to automate their delivery orders.
            </p>
        </field>
    </record>

    <!-- Menu item for delivery carriers -->
    <menuitem id="menu_delivery_carriers"
        name="Delivery Carriers"
        parent="sale.menu_sale_config"
        action="action_delivery_carrier_form"
        sequence="20"/>
</odoo>
