<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_delivery_driver_form" model="ir.ui.view">
        <field name="name">delivery.driver.form</field>
        <field name="model">delivery.driver</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="carrier_company_id"/>
                            <field name="phone"/>
                            <field name="vehicle_info"/>
                            <field name="status"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="portal_user_id"/>
                            <field name="can_send_payment_link" widget="boolean_toggle"/>
                            <field name="delivery_count" string="Deliveries"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_delivery_driver_list" model="ir.ui.view">
        <field name="name">delivery.driver.list</field>
        <field name="model">delivery.driver</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="carrier_company_id"/>
                <field name="phone"/>
                <field name="vehicle_info"/>
                <field name="status"/>
                <field name="portal_user_id"/>
                <field name="delivery_count"/>
            </list>
        </field>
    </record>

    <record id="action_delivery_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">delivery.driver</field>
        <field name="view_mode">list,form</field>
    </record>
  </data>
</odoo>
