<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="paperformat_settlement" model="report.paperformat">
      <field name="name">Settlement Report A4</field>
      <field name="default" eval="False"/>
      <field name="format">A4</field>
      <field name="page_height">0</field>
      <field name="page_width">0</field>
      <field name="orientation">Portrait</field>
      <field name="margin_top">15</field>
      <field name="margin_bottom">15</field>
      <field name="margin_left">7</field>
      <field name="margin_right">7</field>
      <field name="header_line" eval="False"/>
      <field name="header_spacing">10</field>
      <field name="dpi">90</field>
    </record>

    <!-- Link paper format to the report action -->
    <record id="action_settlement_report" model="ir.actions.report">
      <field name="paperformat_id" ref="paperformat_settlement"/>
    </record>
  </data>
</odoo>
