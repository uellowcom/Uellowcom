<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_fraud_rule_list" model="ir.ui.view">
    <field name="name">uellow.fraud.rule.list</field>
    <field name="model">uellow.fraud.rule</field>
    <field name="arch" type="xml">
      <list string="Fraud Rules">
        <field name="name"/>
        <field name="rule_type"/>
        <field name="threshold"/>
        <field name="window_days"/>
        <field name="action" widget="badge"/>
        <field name="score_weight"/>
        <field name="trigger_count"/>
        <field name="active" widget="boolean_toggle"/>
      </list>
    </field>
  </record>
  <record id="view_fraud_case_list" model="ir.ui.view">
    <field name="name">uellow.fraud.case.list</field>
    <field name="model">uellow.fraud.case</field>
    <field name="arch" type="xml">
      <list string="Fraud Cases"
            decoration-danger="state=='confirmed'"
            decoration-warning="state=='open'">
        <field name="name"/>
        <field name="partner_id"/>
        <field name="order_id"/>
        <field name="rule_id"/>
        <field name="risk_score"/>
        <field name="is_blocked" widget="boolean"/>
        <field name="state" widget="badge"/>
        <button name="action_confirm_fraud" string="Confirm" type="object"
                icon="fa-exclamation-triangle"
                invisible="state not in ('open','reviewing')"/>
        <button name="action_false_positive" string="False +" type="object"
                icon="fa-check"
                invisible="state not in ('open','reviewing')"/>
      </list>
    </field>
  </record>
  <record id="view_fraud_case_form" model="ir.ui.view">
    <field name="name">uellow.fraud.case.form</field>
    <field name="model">uellow.fraud.case</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_confirm_fraud" string="Confirm Fraud"
                  type="object" class="btn-danger"
                  invisible="state not in ('open','reviewing')"/>
          <button name="action_false_positive" string="False Positive"
                  type="object" invisible="state not in ('open','reviewing')"/>
          <button name="action_resolve" string="Resolve" type="object"
                  invisible="state in ('resolved','false_pos')"/>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="name" readonly="1"/>
              <field name="partner_id"/>
              <field name="order_id"/>
              <field name="rule_id"/>
            </group>
            <group>
              <field name="risk_score"/>
              <field name="is_blocked"/>
            </group>
          </group>
          <field name="details" readonly="1"/>
          <field name="admin_note"/>
        </sheet>
      </form>
    </field>
  </record>
  <record id="action_fraud_rules" model="ir.actions.act_window">
    <field name="name">Fraud Rules</field>
    <field name="res_model">uellow.fraud.rule</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="action_fraud_cases" model="ir.actions.act_window">
    <field name="name">Fraud Cases</field>
    <field name="res_model">uellow.fraud.case</field>
    <field name="view_mode">list,form</field>
    <field name="domain">[('state','in',('open','reviewing','confirmed'))]</field>
  </record>
</odoo>
