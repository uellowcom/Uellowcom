<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_barcode_session_form" model="ir.ui.view">
    <field name="name">uellow.barcode.session.form</field>
    <field name="model">uellow.barcode.session</field>
    <field name="arch" type="xml">
      <form string="Barcode Receiving Session">
        <header>
          <button name="action_close" string="Close &amp; Validate" type="object"
                  class="oe_highlight" invisible="state!='open'"/>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <group>
            <field name="request_id"/><field name="user_id" readonly="1"/>
            <field name="total_scanned" readonly="1"/><field name="total_lines" readonly="1"/>
          </group>
          <field name="scan_ids">
            <list>
              <field name="scan_time"/><field name="barcode"/>
              <field name="product_id"/><field name="variant_description" readonly="1"/>
              <field name="qty_scanned"/>
              <field name="status" widget="badge" decoration-success="status=='ok'" decoration-danger="status in ('unknown','mismatch')"/>
            </list>
          </field>
        </sheet>
      </form>
    </field>
  </record>
  <record id="action_barcode_sessions" model="ir.actions.act_window">
    <field name="name">Barcode Sessions</field>
    <field name="res_model">uellow.barcode.session</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
