<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Mobile User Form View -->
    <record id="view_mobile_user_form" model="ir.ui.view">
        <field name="name">mobile.user.form</field>
        <field name="model">mobile.user</field>
        <field name="arch" type="xml">
            <form string="Mobile User">
                <sheet>
                    <group>
                        <group>
                            <field name="username"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="last_login"/>
                            <field name="device_id"/>
                            <field name="device_token"/>
                            <field name="device_platform"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Mobile User Tree View -->
    <record id="view_mobile_user_tree" model="ir.ui.view">
        <field name="name">mobile.user.tree</field>
        <field name="model">mobile.user</field>
        <field name="arch" type="xml">
            <tree string="Mobile Users">
                <field name="username"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="last_login"/>
                <field name="device_platform"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Mobile User Search View -->
    <record id="view_mobile_user_search" model="ir.ui.view">
        <field name="name">mobile.user.search</field>
        <field name="model">mobile.user</field>
        <field name="arch" type="xml">
            <search string="Mobile Users">
                <field name="username"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Partner" name="partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="User" name="user" context="{'group_by': 'user_id'}"/>
                    <filter string="Platform" name="platform" context="{'group_by': 'device_platform'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Mobile User Action -->
    <record id="action_mobile_user" model="ir.actions.act_window">
        <field name="name">Mobile Users</field>
        <field name="res_model">mobile.user</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mobile_user_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new mobile user
            </p>
            <p>
                Mobile users can access the mobile application using their credentials.
            </p>
        </field>
    </record>
</odoo>
