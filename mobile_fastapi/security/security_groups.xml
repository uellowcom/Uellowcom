<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- ========================================== -->
    <!-- USERS FOR API ENDPOINTS                    -->
    <!-- ========================================== -->
    
    <!-- Production API User -->
    <record id="mobile_api_user" model="res.users" context="{'no_reset_password': True}">
        <field name="name">Mobile API User</field>
        <field name="login">mobile_api_user</field>
        <field name="email">mobile.api@uellow.com</field>
        <field name="groups_id" eval="[(6, 0, [])]"/>
        <field name="active" eval="True"/>
    </record>

    <!-- Development API User -->
    <record id="mobile_api_dev_user" model="res.users" context="{'no_reset_password': True}">
        <field name="name">Mobile API Dev User</field>
        <field name="login">mobile_api_dev_user</field>
        <field name="email">mobile.api.dev@uellow.com</field>
        <field name="groups_id" eval="[(6, 0, [])]"/>
        <field name="active" eval="True"/>
    </record>

    <!-- Testing API User -->
    <record id="mobile_api_test_user" model="res.users" context="{'no_reset_password': True}">
        <field name="name">Mobile API Test User</field>
        <field name="login">mobile_api_test_user</field>
        <field name="email">mobile.api.test@uellow.com</field>
        <field name="groups_id" eval="[(6, 0, [])]"/>
        <field name="active" eval="True"/>
    </record>

    <!-- ========================================== -->
    <!-- SECURITY GROUP                             -->
    <!-- ========================================== -->
    
    <!-- Create a security group for the Mobile API -->
    <record id="mobile_api_group" model="res.groups">
        <field name="name">Mobile API Access Group</field>
        <field name="comment">Security group for mobile API endpoint with minimal permissions</field>
        <field name="users" eval="[(4, ref('mobile_api_user')), (4, ref('mobile_api_dev_user')), (4, ref('mobile_api_test_user'))]"/>
        <!-- This group inherits from the base FastAPI endpoint runner group -->
        <field name="implied_ids" eval="[(4, ref('fastapi.group_fastapi_endpoint_runner'))]"/>
    </record>

</odoo>
