<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- FastAPI App Configuration for Mobile API -->
        <record id="fastapi_endpoint_mobile" model="fastapi.endpoint">
            <field name="name">Mobile API v1</field>
            <field name="route_prefix">/mobile</field>
            <field name="app">mobile_api.main:app</field>
            <field name="config_id" ref="fastapi.default_fastapi_config"/>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <!-- Mobile API Routes Registration -->
        <record id="mobile_auth_endpoints" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/auth</field>
            <field name="request_method">GET,POST,PUT,DELETE</field>
            <field name="name">Mobile Authentication</field>
        </record>

        <record id="mobile_product_endpoints" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/products</field>
            <field name="request_method">GET,POST,PUT,DELETE</field>
            <field name="name">Mobile Products</field>
        </record>

        <record id="mobile_home_endpoints" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/home</field>
            <field name="request_method">GET</field>
            <field name="name">Mobile Home</field>
        </record>

        <record id="mobile_wallet_endpoints" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/wallet</field>
            <field name="request_method">GET,POST,PUT</field>
            <field name="name">Mobile Wallet</field>
        </record>

        <record id="mobile_notification_endpoints" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/notifications</field>
            <field name="request_method">GET,POST,PUT,DELETE</field>
            <field name="name">Mobile Notifications</field>
        </record>

        <!-- Health Check and Documentation Routes -->
        <record id="mobile_health_endpoint" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/health</field>
            <field name="request_method">GET</field>
            <field name="name">Mobile Health Check</field>
        </record>

        <record id="mobile_docs_endpoint" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/docs</field>
            <field name="request_method">GET</field>
            <field name="name">Mobile API Documentation</field>
        </record>

        <record id="mobile_redoc_endpoint" model="fastapi.endpoint.route">
            <field name="endpoint_id" ref="fastapi_endpoint_mobile"/>
            <field name="route">/mobile/v1/redoc</field>
            <field name="request_method">GET</field>
            <field name="name">Mobile API ReDoc</field>
        </record>

        <!-- CORS Configuration for Mobile Apps -->
        <record id="mobile_cors_config" model="ir.config_parameter">
            <field name="key">mobile_api.cors.allow_origins</field>
            <field name="value">["*"]</field>
        </record>

        <record id="mobile_cors_methods" model="ir.config_parameter">
            <field name="key">mobile_api.cors.allow_methods</field>
            <field name="value">["GET", "POST", "PUT", "DELETE", "OPTIONS"]</field>
        </record>

        <record id="mobile_cors_headers" model="ir.config_parameter">
            <field name="key">mobile_api.cors.allow_headers</field>
            <field name="value">["*"]</field>
        </record>

    </data>
</odoo>
